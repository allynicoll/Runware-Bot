# From discord.com/developers/applications
DISCORD_TOKEN=

# From discord.com/developers/applications → General Information → Application ID
DISCORD_CLIENT_ID=

# The ID of your Discord server
DISCORD_GUILD_ID=

# Your Runware API key — covers all commands including AI inference (/build, /recommend, /compare)
RUNWARE_API_KEY=

# Optional: restrict /build, /recommend, and /compare to members with this role ID.
# Right-click a role in Server Settings → Copy Role ID (requires Developer Mode).
# Leave blank to allow all server members to use AI commands.
AI_COMMAND_ROLE_ID=

# Optional: post new-model announcements to this channel automatically (hourly check).
# Right-click a channel → Copy Channel ID (requires Developer Mode).
ANNOUNCE_CHANNEL_ID=

# Optional: override the Runware textInference model used by AI commands.
# Default: anthropic:claude@sonnet-4.6
INFERENCE_MODEL=
